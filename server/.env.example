# Скопируй этот файл в .env и подставь свои значения
PORT=4000

# PostgreSQL (например, бесплатная база на neon.tech):
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Секрет для подписи JWT-токенов. Поставь свой длинный случайный.
JWT_SECRET="change-me-to-long-random-string"
