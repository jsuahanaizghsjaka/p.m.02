# Скопируй этот файл в .env и подставь свои значения
PORT=4000
# Локально используем SQLite (файл создаётся автоматически):
DATABASE_URL="file:./dev.db"
# На деплое заменим на PostgreSQL, например:
# DATABASE_URL="postgresql://user:password@host:5432/tracker"

# Секрет для подписи JWT-токенов. На деплое поставь свой длинный случайный.
JWT_SECRET="local-dev-secret-please-change"
